# Copia este archivo como .streamlit/secrets.toml (gitignored) para desarrollo local.
# En Streamlit Community Cloud: share.streamlit.io -> app -> Settings -> Secrets.

# Clave de acceso al panel de administración
admin_password = "cambia-esta-clave"

# GitHub PAT para sincronizar data/live/*.csv al repo tras cada partido.
# Permisos mínimos: Contents → Read and write (solo este repo).
# Crear en: github.com -> Settings -> Developer settings -> Personal access tokens -> Fine-grained.
# Sin este token el store funciona igual pero los datos no persisten entre reinicios de Cloud.
github_token = "ghp_xxxxxxxxxxxxxxxxxxxx"

# Opcionales — solo si cambias de fork o de rama
# github_repo = "NicoBJ1906/mundial-2026-ml"
# github_branch = "main"
